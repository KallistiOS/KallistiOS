#!/bin/sh

# Make sure what mode we're in. The basic cc wrapper does a lot.
ARGS=$*
USEMODE=0
for i in $ARGS; do
	case "${i}" in
		@*)
			ARGS="${ARGS} $(cat ${i#*@})"
		;;
	esac
done
for i in $ARGS; do
	case "${i}" in
		-o)
			if [ $USEMODE != 2 -a $USEMODE != 3 ]; then
				# Link
				USEMODE=1
			fi
		;;
		-c | -S | -E)
			# Partial compile
			USEMODE=2
		;;
		conftest.c | conftest.cc | conftest.cpp | conftest__.c | conftest__.cc | conftest__.cpp)
			# Used in autoconf... we really probably need
			# a better way to do this. (scan for any .c?)
			USEMODE=3
		;;
		-dumpversion)
			# Used for our gcc version test which expects
			# *just* the output and no verbose output.
			USEMODE=4
		;;
		*)
		;;
	esac
done

# If building for coverage (--coverage), route each translation unit's gcov_info
# into a linker section named "gcov_info". That name is a valid C identifier, so
# GNU ld auto-provides __start_gcov_info/__stop_gcov_info and no linker-script
# edit is needed. Also auto-link the .gcda writer (libkosgcov) and GCC's own
# libgcov runtime, so a plain "kos-cc --coverage" just works.
COVERAGE=0
for i in $ARGS; do
	case "${i}" in
		--coverage | -coverage | -ftest-coverage)
			COVERAGE=1
		;;
	esac
done
GCOV_CFLAGS=""
GCOV_LIBS=""
if [ ${COVERAGE} = 1 ]; then
	GCOV_CFLAGS="-fprofile-info-section=gcov_info"
	# Force-include the whole addon so its constructor (the at-exit flush)
	# is linked even though the program references nothing in it -- no source
	# changes needed.
	GCOV_LIBS="-Wl,--whole-archive -lkosgcov -Wl,--no-whole-archive $(${KOS_CC} -print-file-name=libgcov.a)"
fi

case $USEMODE in
	0)
		# Unknown mode ... use default args and cross fingers.
		if [ x${KOS_WRAPPERS_VERBOSE} = x"1" ]; then
			echo ${KOS_CC} "$@"
		fi
		exec ${KOS_CC} "$@"
	;;

	1)
		# In link mode, add all the extra processing.
		if [ x${KOS_WRAPPERS_VERBOSE} = x"1" ]; then
			echo ${KOS_CC} ${KOS_CFLAGS} ${GCOV_CFLAGS} ${KOS_LDFLAGS} "$@" ${GCOV_LIBS} ${KOS_LIBS}
		fi
		exec ${KOS_CC} ${KOS_CFLAGS} ${GCOV_CFLAGS} ${KOS_LDFLAGS} "$@" ${GCOV_LIBS} ${KOS_LIBS}
	;;

	3)
		# Link mode for autoconf: pass -fno-lto to speed up process
		if [ x${KOS_WRAPPERS_VERBOSE} = x"1" ]; then
			echo ${KOS_CC} ${KOS_CFLAGS} ${KOS_LDFLAGS} -fno-lto "$@" ${KOS_LIBS}
		fi
		exec ${KOS_CC} ${KOS_CFLAGS} ${KOS_LDFLAGS} -fno-lto "$@" ${KOS_LIBS}
	;;

	2)
		# In non-link mode, just go ahead and run CC.
		if [ x${KOS_WRAPPERS_VERBOSE} = x"1" ]; then
			echo ${KOS_CC} ${KOS_CFLAGS} ${GCOV_CFLAGS} "$@"
		fi
		exec ${KOS_CC} ${KOS_CFLAGS} ${GCOV_CFLAGS} "$@"
	;;

	4)
		# -dumpversion mode. Ignore verbose.
		exec ${KOS_CC} "$@"
	;;
esac
